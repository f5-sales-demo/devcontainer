{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI Proxy",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 200000,
            "output": 128000
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "grok-code-fast-1": {
          "name": "Grok Code Fast 1",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 256000,
            "output": 256000
          }
        }
      }
    }
  },
  "model": "openai-proxy/claude-opus-4-6",
  "small_model": "openai-proxy/claude-sonnet-4-6",
  "plugin": ["@robinmordasiewicz/oh-my-opencode@3.11.0-fork.1"]
}
