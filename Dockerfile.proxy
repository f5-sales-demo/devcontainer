FROM python:3.13-slim
# OpenAI-compatible API proxy — translates between API formats
WORKDIR /app

# Install uv for fast dependency management
RUN pip install --no-cache-dir uv

# Clone the proxy and install dependencies
# Build tools are needed for C extensions (httptools, uvloop) on Python 3.13
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
        git build-essential \
    && git clone https://github.com/fuergaosi233/claude-code-proxy.git . \
    && uv sync \
    && apt-get purge -y git build-essential \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r proxyuser && useradd -r -g proxyuser proxyuser \
    && chown -R proxyuser:proxyuser /app
USER proxyuser

EXPOSE 8082

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8082/')" || exit 1

CMD ["uv", "run", "python", "start_proxy.py"]
