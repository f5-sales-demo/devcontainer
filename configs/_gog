        '(-v --verbose)'{-v,--verbose}'[Enable verbose logging]' \
        '--version[Print version and exit]' \
        "1:command:_gog_tasks_commands" \
        "*::arg:->args"

    case $state in
        args)
            case $words[1] in
                add|create) _gog_tasks_add ;;
                clear) _gog_tasks_clear ;;
                delete|del|remove|rm) _gog_tasks_delete ;;
                done|complete) _gog_tasks_done ;;
                get|info|show) _gog_tasks_get ;;
                list|ls) _gog_tasks_list ;;
                lists) _gog_tasks_lists ;;
                undo|uncomplete|undone) _gog_tasks_undo ;;
