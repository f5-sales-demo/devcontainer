_gog_tasks() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--access-token=[Use provided access token directly (bypasses stored refresh tokens; token expires in ~1h)]:value: ' \
        '(-a --account)'{-a,--account}'=[Account email for API commands (gmail/calendar/chat/classroom/drive/docs/slides/contacts/tasks/people/sheets/forms/appscript)]:value: ' \
        '--client=[OAuth client name (selects stored credentials + token bucket)]:value: ' \
        '--color=[Color output: auto|always|never]:value: ' \
        '(-n --dry-run)'{-n,--dry-run}'[Do not make changes; print intended actions and exit successfully]' \
        '--enable-commands=[Comma-separated list of enabled top-level commands (restricts CLI)]:value: ' \
        '(-y --force)'{-y,--force}'[Skip confirmations for destructive commands]' \
        '(-h --help)'{-h,--help}'[Show context-sensitive help.]' \
        '(-j --json)'{-j,--json}'[Output JSON to stdout (best for scripting)]' \
