#!/usr/bin/env bash
# lessfilter — delegates syntax highlighting to bat when available.
# Invoked automatically by less via LESSOPEN="|~/.lessfilter %s".

if command -v bat > /dev/null 2>&1; then
    bat --color=always --style=plain --paging=never -- "$1"
    exit 0
fi

# Fall through to default less behavior
exit 1
