# =============================================================================
# AI Proxy — REQUIRED
# =============================================================================
# Your OpenAI-compatible API endpoint and key.

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://your-api-endpoint.example.com/v1

# =============================================================================
# Model Mapping
# =============================================================================
# Map AI tool requests to your backend model names.

BIG_MODEL=gpt-4o
MIDDLE_MODEL=gpt-4o
SMALL_MODEL=gpt-4o-mini

# =============================================================================
# Host User Mapping
# =============================================================================
# Auto-detect (run once):
#   echo "USER_GID=$(id -g)" >> .env
#   echo "USER_UID=$(id -u)" >> .env
#   echo "USERNAME=$(whoami)" >> .env

USER_GID=1000
USER_UID=1000
USERNAME=vscode

# =============================================================================
# Git Config
# =============================================================================

GIT_AUTHOR_EMAIL=you@example.com
GIT_AUTHOR_NAME="Your Name"

# =============================================================================
# SSH Key (optional — for git clone over SSH)
# =============================================================================
# Base64 encode your private key:
#   echo "SSH_PRIVATE_KEY=$(base64 < ~/.ssh/id_ed25519)" >> .env

# SSH_PRIVATE_KEY=

# =============================================================================
# Optional
# =============================================================================

# ANTHROPIC_API_KEY=changeme
# LOG_LEVEL=WARNING
# MAX_TOKENS_LIMIT=64000
# REQUEST_TIMEOUT=120
