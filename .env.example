# =============================================================================
# .env.example — Configuration template for the devcontainer
# =============================================================================
#
# Quick start:
#   cp .env.example .env    # then edit .env with your values
#
# Auto-detect support:
#   Variables marked with @auto-detect can be populated automatically.
#   Each @auto-detect comment contains a shell command that outputs the
#   correct value. Run the @check command first to verify prerequisites.
#
#   AI assistants (Claude Code, OpenCode, etc.): When helping a user create
#   or update a .env file, follow this workflow:
#
#   1. Check if .env already exists. If yes, read it and enhance in-place —
#      only update variables that are missing or still have placeholder values
#      (e.g., "sk-example-api-key-here", "you@example.com", "Example Name").
#      If no .env exists, start with: cp .env.example .env
#
#   2. For each @auto-detect marker, run the @check command first. If it
#      succeeds (exit 0), run the @auto-detect command and write the result
#      to .env. If @check fails, skip that variable.
#
#   3. For each @manual marker, prompt the user — explain what the variable
#      does, where to get the value, and ask if they want to set it now.
#
#   4. After processing all markers, summarize what was auto-detected, what
#      was skipped, and what still needs manual configuration.
#
#   Never hard-code or guess secrets.
#
# =============================================================================

# =============================================================================
# AI Provider — REQUIRED (choose ONE mode)
# =============================================================================
# Two mutually exclusive authentication modes (in priority order):
#
#   LiteLLM proxy: Set LITELLM_API_KEY and LITELLM_BASE_URL.
#                  OpenCode and Claude Code both connect through the same proxy.
#
#   OAuth mode:   Set CLAUDE_CODE_OAUTH_TOKEN only (see Claude Max section below).
# @manual: get the shared LiteLLM API key from your proxy administrator

LITELLM_API_KEY=sk-example-api-key-here

# =============================================================================
# Claude Max (OAuth) — OPTIONAL (alternative to API key)
# =============================================================================
# If you have a Claude Max subscription, set your OAuth token instead of an
# API key.  Get it from Claude Code settings or the Anthropic console.
# When set, Claude Code, OpenCode, OpenClaw, and Pi all authenticate via OAuth.
# @auto-detect: security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])"
# @requires: Claude Code authenticated on macOS (stores token in system keychain)
# @check: security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | python3 -c "import sys,json; json.load(sys.stdin)['claudeAiOauth']['accessToken']"
# @manual: get a token from Claude Code settings or https://console.anthropic.com/

# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-example-token-here

# =============================================================================
# LiteLLM Proxy — REQUIRED (for OpenCode and Claude Code proxy mode)
# =============================================================================
# This variable is used by the startup script to derive the OpenAI-compatible
# and Anthropic-compatible proxy URLs consumed by OpenCode and Claude Code.
# Set the domain only — the script appends the required path suffixes.
# @manual: get the base URL from your proxy administrator

LITELLM_BASE_URL=https://proxy.example.com

# =============================================================================
# Timezone — OPTIONAL
# =============================================================================
# Set your IANA timezone so container timestamps match your local clock.
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# @auto-detect: readlink /etc/localtime | sed 's|.*/zoneinfo/||'
# @requires: /etc/localtime symlink (macOS and most Linux)
# @check: readlink /etc/localtime

# TZ=America/New_York

# =============================================================================
# Git Config
# =============================================================================
# The entrypoint derives GIT_COMMITTER_NAME and GIT_COMMITTER_EMAIL from these
# automatically, so you only need to set the AUTHOR variables.
#
# @auto-detect: git config user.email
# @requires: git with user.email configured
# @check: git config user.email
GIT_AUTHOR_EMAIL=you@example.com

# @auto-detect: git config user.name
# @requires: git with user.name configured
# @check: git config user.name
GIT_AUTHOR_NAME="Example Name"

# =============================================================================
# SSH Key (optional — for git clone over SSH)
# =============================================================================
# @auto-detect: base64 < ~/.ssh/id_ed25519
# @requires: SSH key at ~/.ssh/id_ed25519
# @check: test -f ~/.ssh/id_ed25519
# Manual: echo "SSH_PRIVATE_KEY=$(base64 < ~/.ssh/id_ed25519)" >> .env

# SSH_PRIVATE_KEY=

# =============================================================================
# GitHub CLI — OPTIONAL (for gh commands and HTTPS git clone)
# =============================================================================
# A GitHub personal access token for the gh CLI and HTTPS git operations.
# Also enables HTTPS git clone/push without SSH keys.
# @auto-detect: gh auth token
# @requires: gh CLI installed and authenticated (gh auth login)
# @check: gh auth status
#
# @manual: create a token at https://github.com/settings/tokens
# Fine-grained tokens (recommended) or classic tokens (requires "repo" scope).

# GH_TOKEN=ghp_example-token-here

# =============================================================================
# Google CLI Tools — OPTIONAL (gogcli + gws)
# =============================================================================
# Shared OAuth client credentials used by both gog (gogcli) and gws
# (Google Workspace CLI). Both tools use the same Google Cloud OAuth client.
# The entrypoint decodes these and writes config files for each tool.
#
# GOG_ACCOUNT: default Google account email for gog commands.
# GOG_CREDENTIALS_JSON: base64-encoded OAuth client credentials.json
# GOG_TOKEN_JSON: base64-encoded token export from `gog auth tokens export`
# GWS_CLIENT_SECRET_JSON: base64-encoded client_secret.json for gws
# GWS_ENCRYPTION_KEY: encryption key for gws credential store
# GWS_CREDENTIALS_ENC: base64-encoded encrypted credentials blob
# GWS_TOKEN_CACHE: base64-encoded token_cache.json (encrypted token store)
#
# @auto-detect: gog auth list --plain 2>/dev/null | head -1 | cut -f1
# @requires: gog CLI installed and authenticated (gog auth add)
# @check: gog auth list --plain 2>/dev/null | head -1

# GOG_ACCOUNT=you@gmail.com

# @auto-detect: base64 < "$(gog auth status --plain 2>/dev/null | grep credentials_path | cut -f2)"
# @requires: gog CLI with stored credentials
# @check: gog auth status --plain 2>/dev/null | grep credentials_exists | grep -q true

# GOG_CREDENTIALS_JSON=

# @auto-detect: gog auth tokens export <email> --out /tmp/gog-token-export.json --overwrite 2>/dev/null && base64 < /tmp/gog-token-export.json && rm /tmp/gog-token-export.json
# @requires: gog CLI with an authorized account
# @check: gog auth list --plain 2>/dev/null | head -1

# GOG_TOKEN_JSON=

# @auto-detect: base64 < ~/.config/gws/client_secret.json
# @requires: gws CLI configured with OAuth client
# @check: test -f ~/.config/gws/client_secret.json

# GWS_CLIENT_SECRET_JSON=

# @auto-detect: security find-generic-password -s "gws-cli" -w 2>/dev/null || cat ~/.config/gws/.encryption_key 2>/dev/null
# @requires: gws CLI authenticated (gws auth login)
# @check: test -f ~/.config/gws/credentials.enc

# GWS_ENCRYPTION_KEY=

# @auto-detect: base64 < ~/.config/gws/credentials.enc
# @requires: gws CLI authenticated (gws auth login)
# @check: test -f ~/.config/gws/credentials.enc

# GWS_CREDENTIALS_ENC=

# @auto-detect: base64 < ~/.config/gws/token_cache.json
# @requires: gws CLI authenticated (gws auth login)
# @check: test -f ~/.config/gws/token_cache.json

# GWS_TOKEN_CACHE=

# =============================================================================
# Docker / Podman Socket (DooD) — OPTIONAL
# =============================================================================
# Mount the host container runtime socket so Docker CLI inside the container
# can build images and manage containers on your workstation.
#
# Docker Desktop / Docker Engine (default — no .env entry needed):
#   The socket at /var/run/docker.sock is used automatically.
#
# Rootless Podman (no sudo required):
#   Set DOCKER_SOCK to your Podman user socket.
#   First enable the socket: systemctl --user start podman.socket
#   Then set DOCKER_SOCK below (replace 1000 with your UID: id -u).
#
# @auto-detect: echo "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/podman/podman.sock"
# @requires: rootless Podman with socket enabled (systemctl --user start podman.socket)
# @check: test -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/podman/podman.sock"

# DOCKER_SOCK=/run/user/1000/podman/podman.sock

# =============================================================================
# VNC Remote Desktop — OPTIONAL
# =============================================================================
# Start the VNC stack (Xvfb + fluxbox + x11vnc + noVNC) for GUI access.
# Access via browser at http://localhost:6080

# ENABLE_VNC=true
# VNC_RESOLUTION=1280x1024x24
# VNC_PORT=5900
# NOVNC_PORT=6080

# =============================================================================
# Port Overrides — OPTIONAL (for running multiple containers)
# =============================================================================
# Override host-side ports to avoid conflicts when running multiple containers.
# Only needed when another devcontainer instance is already using the defaults.

# NOVNC_HOST_PORT=7080

# =============================================================================
# Tailscale VPN — OPTIONAL
# =============================================================================
# Connect the container to your Tailscale network for secure access to
# private resources.  Generate an auth key at:
#   https://login.tailscale.com/admin/settings/keys

# ENABLE_TAILSCALE=true
# @manual: generate at https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTHKEY=tskey-auth-example-key-here
